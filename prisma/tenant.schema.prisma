datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique // ADMIN, MAIN_TEACHER, SUBJECT_TEACHER, PARENT, STUDENT
  users User[]

  @@map("roles")
}

model User {
  id            Int     @id @default(autoincrement())
  email         String? @unique
  phone         String  @unique
  password_hash String
  first_name    String
  last_name     String
  middle_name   String?
  passport      String?
  telegram_id   String? @unique
  role_id       Int
  role          Role    @relation(fields: [role_id], references: [id])

  // Soft Delete fields
  is_deleted Boolean   @default(false)
  deleted_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // 1:1 relation to Student profile if the user is a student
  student UserStudent?

  // Parent profile references (many-to-many relationship helper)
  parent_students StudentParent[]

  // Teacher relationships
  class_teachers ClassTeacher[]
  graded_grades  Grade[]

  // Announcements authored
  announcements Announcement[]

  // Audit Logs
  audit_logs AuditLog[]

  grade_comments         GradeComment[]
  menu_comments_authored MenuComment[]  @relation("MenuCommentAuthor")
  menu_comments_parented MenuComment[]  @relation("MenuCommentParent")
  clubs                  Club[]

  @@map("users")
}

model UserStudent {
  id         Int             @id @default(autoincrement())
  user_id    Int             @unique
  user       User            @relation(fields: [user_id], references: [id])
  class_id   Int
  class      Class           @relation(fields: [class_id], references: [id])
  is_deleted Boolean         @default(false)
  deleted_at DateTime?

  // Extended profile and balance fields
  address    String?
  birthdate  DateTime?       @db.Date
  ina        String?
  balance    Decimal         @default(0.00) @db.Decimal(12, 2)

  parents    StudentParent[]
  grades     Grade[]
  codes      ParentAccessCode[]
  payment_transactions PaymentTransaction[]
  charge_plans ChargePlanStudent[]
  charge_logs ChargeLog[]
  announcements AnnouncementStudent[]
  clubs ClubStudent[]

  @@map("students")
}

// Explicit many-to-many mapping for Student and Parent
model StudentParent {
  student_id    Int
  parent_id     Int
  relation_type String @default("ota")

  student UserStudent @relation(fields: [student_id], references: [id])
  parent  User        @relation(fields: [parent_id], references: [id])

  @@id([student_id, parent_id])
  @@map("student_parents")
}

model Class {
  id         Int           @id @default(autoincrement())
  name       String        @unique // e.g. "5-A", "11-B"
  level      Int           @default(1)
  is_deleted Boolean       @default(false)
  deleted_at DateTime?
  students   UserStudent[]
  teachers   ClassTeacher[]
  charge_plans ChargePlanClass[]
  announcements AnnouncementClass[]

  @@map("classes")
}

model Subject {
  id         Int            @id @default(autoincrement())
  name       String         @unique // e.g. "Matematika", "Fizika"
  is_deleted Boolean        @default(false)
  deleted_at DateTime?
  teachers   ClassTeacher[]
  grades     Grade[]
  clubs      Club[]

  @@map("subjects")
}

model ClassTeacher {
  id              Int     @id @default(autoincrement())
  class_id        Int
  subject_id      Int
  teacher_id      Int
  is_main_teacher Boolean @default(false)
  is_deleted      Boolean @default(false)
  deleted_at      DateTime?
  class           Class   @relation(fields: [class_id], references: [id])
  subject         Subject @relation(fields: [subject_id], references: [id])
  teacher         User    @relation(fields: [teacher_id], references: [id])

  @@unique([class_id, subject_id, teacher_id])
  @@map("class_teachers")
}

model Grade {
  id            Int         @id @default(autoincrement())
  student_id    Int
  subject_id    Int
  teacher_id    Int
  value         String
  numeric_value Decimal?    @db.Decimal(5, 2)
  grade_date    DateTime
  is_deleted     Boolean     @default(false)
  deleted_at     DateTime?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  
  grade_type     String      @default("MASTERY")
  grade_category String      @default("DAILY")
  lesson_number  Int?

  student        UserStudent @relation(fields: [student_id], references: [id])
  subject        Subject     @relation(fields: [subject_id], references: [id])
  teacher        User        @relation(fields: [teacher_id], references: [id])
  comments       GradeComment[]

  @@map("grades")
}

model GradingSystem {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  type       String
  min_value  Decimal? @db.Decimal(5, 2)
  max_value  Decimal? @db.Decimal(5, 2)
  options    Json?
  is_active  Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("grading_systems")
}

model ParentAccessCode {
  id           Int         @id @default(autoincrement())
  student_id   Int
  parent_phone String
  code         String      @unique
  is_used      Boolean     @default(false)
  created_at   DateTime    @default(now())
  expires_at   DateTime
  student      UserStudent @relation(fields: [student_id], references: [id])

  @@map("parent_access_codes")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  action     String
  table_name String
  record_id  String
  old_values Json?
  new_values Json?
  ip_address String?
  user_agent String?
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id])

  @@map("audit_logs")
}

model PaymentTransaction {
  id          Int         @id @default(autoincrement())
  student_id  Int
  student     UserStudent @relation(fields: [student_id], references: [id])
  amount      Decimal     @db.Decimal(12, 2)
  type        String      // 'PAYMENT' or 'CHARGE'
  description String?
  created_at  DateTime    @default(now())
  charge_logs ChargeLog[]

  @@map("payment_transactions")
}

model SchoolHoliday {
  id           Int       @id @default(autoincrement())
  holiday_date DateTime  @unique @db.Date
  name         String
  is_deleted   Boolean   @default(false)
  deleted_at   DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@map("school_holidays")
}

model MenuInterval {
  id           Int         @id @default(autoincrement())
  name         String      @db.VarChar(100)
  start_date   DateTime    @db.Date
  end_date     DateTime    @db.Date
  cycle_weeks  Int
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt
  menu_cycles  MenuCycle[]

  @@map("menu_intervals")
}

model MenuCycle {
  id           Int          @id @default(autoincrement())
  interval_id  Int
  week_number  Int
  day_of_week  Int
  meals        Json
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  interval     MenuInterval @relation(fields: [interval_id], references: [id], onDelete: Cascade)

  @@unique([interval_id, week_number, day_of_week])
  @@map("menu_cycles")
}

model MenuException {
  id          Int      @id @default(autoincrement())
  menu_date   DateTime @unique @db.Date
  meals       Json?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("menu_exceptions")
}

model ChargePlan {
  id           Int                  @id @default(autoincrement())
  name         String
  amount       Decimal              @db.Decimal(12, 2)
  start_date   DateTime             @db.Date
  end_date     DateTime             @db.Date
  charge_day   Int
  created_at   DateTime             @default(now())
  updated_at   DateTime             @updatedAt
  levels       ChargePlanLevel[]
  classes      ChargePlanClass[]
  students     ChargePlanStudent[]
  logs         ChargeLog[]

  @@map("charge_plans")
}

model ChargePlanLevel {
  charge_plan_id Int
  level          Int
  charge_plan    ChargePlan @relation(fields: [charge_plan_id], references: [id], onDelete: Cascade)

  @@id([charge_plan_id, level])
  @@map("charge_plan_levels")
}

model ChargePlanClass {
  charge_plan_id Int
  class_id       Int
  charge_plan    ChargePlan @relation(fields: [charge_plan_id], references: [id], onDelete: Cascade)
  class          Class      @relation(fields: [class_id], references: [id], onDelete: Cascade)

  @@id([charge_plan_id, class_id])
  @@map("charge_plan_classes")
}

model ChargePlanStudent {
  charge_plan_id Int
  student_id     Int
  charge_plan    ChargePlan  @relation(fields: [charge_plan_id], references: [id], onDelete: Cascade)
  student        UserStudent @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@id([charge_plan_id, student_id])
  @@map("charge_plan_students")
}

model ChargeLog {
  id             Int                  @id @default(autoincrement())
  charge_plan_id Int
  student_id     Int
  billing_month  DateTime             @db.Date
  transaction_id Int?
  created_at     DateTime             @default(now())
  charge_plan    ChargePlan           @relation(fields: [charge_plan_id], references: [id], onDelete: Cascade)
  student        UserStudent          @relation(fields: [student_id], references: [id], onDelete: Cascade)
  transaction    PaymentTransaction?  @relation(fields: [transaction_id], references: [id], onDelete: SetNull)

  @@unique([charge_plan_id, student_id, billing_month])
  @@map("charge_logs")
}

model Announcement {
  id         Int                   @id @default(autoincrement())
  title      String
  content    String
  author_id  Int
  author     User                  @relation(fields: [author_id], references: [id])
  is_deleted Boolean               @default(false)
  deleted_at DateTime?
  created_at DateTime              @default(now())
  updated_at DateTime              @updatedAt
  classes    AnnouncementClass[]
  levels     AnnouncementLevel[]
  students   AnnouncementStudent[]

  @@map("announcements")
}

model AnnouncementClass {
  announcement_id Int
  class_id       Int
  announcement   Announcement @relation(fields: [announcement_id], references: [id], onDelete: Cascade)
  class          Class        @relation(fields: [class_id], references: [id], onDelete: Cascade)

  @@id([announcement_id, class_id])
  @@map("announcement_classes")
}

model AnnouncementLevel {
  announcement_id Int
  level           Int
  announcement    Announcement @relation(fields: [announcement_id], references: [id], onDelete: Cascade)

  @@id([announcement_id, level])
  @@map("announcement_levels")
}

model AnnouncementStudent {
  announcement_id Int
  student_id      Int
  announcement    Announcement @relation(fields: [announcement_id], references: [id], onDelete: Cascade)
  student         UserStudent  @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@id([announcement_id, student_id])
  @@map("announcement_students")
}

model GradeComment {
  id         Int      @id @default(autoincrement())
  grade_id   Int
  grade      Grade    @relation(fields: [grade_id], references: [id], onDelete: Cascade)
  author_id  Int
  author     User     @relation(fields: [author_id], references: [id], onDelete: Cascade)
  content    String
  created_at DateTime @default(now())

  @@map("grade_comments")
}

model MenuComment {
  id         Int      @id @default(autoincrement())
  menu_date  DateTime @db.Date
  parent_id  Int
  parent     User     @relation("MenuCommentParent", fields: [parent_id], references: [id], onDelete: Cascade)
  author_id  Int
  author     User     @relation("MenuCommentAuthor", fields: [author_id], references: [id], onDelete: Cascade)
  content    String
  created_at DateTime @default(now())

  @@map("menu_comments")
}

model Club {
  id                   Int            @id @default(autoincrement())
  name                 String
  subject_id           Int
  subject              Subject        @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  teacher_id           Int
  teacher              User           @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
  allowed_class_levels Int[]
  is_deleted           Boolean        @default(false)
  deleted_at           DateTime?
  created_at           DateTime       @default(now())
  updated_at           DateTime       @default(now()) @updatedAt
  students             ClubStudent[]
  schedules            ClubSchedule[]

  @@map("clubs")
}

model ClubStudent {
  id         Int      @id @default(autoincrement())
  club_id    Int
  club       Club     @relation(fields: [club_id], references: [id], onDelete: Cascade)
  student_id Int
  student    UserStudent @relation(fields: [student_id], references: [id], onDelete: Cascade)
  status     String   @default("APPROVED")
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@unique([club_id, student_id])
  @@map("club_students")
}

model ClubSchedule {
  id          Int      @id @default(autoincrement())
  club_id     Int
  club        Club     @relation(fields: [club_id], references: [id], onDelete: Cascade)
  day_of_week Int
  start_time  String
  end_time    String
  is_deleted  Boolean  @default(false)
  deleted_at  DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  @@map("club_schedules")
}
